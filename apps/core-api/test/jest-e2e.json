{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@omaha/db$": "<rootDir>/../../../packages/db/src",
    "^@omaha/shared-types$": "<rootDir>/../../../packages/shared-types/src"
  }
}
