generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemSetting {
  key   String @id
  value String

  @@map("system_settings")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users              User[]
  roles              Role[]
  objectTypes        ObjectType[]
  objectRelationships ObjectRelationship[]
  connectors         Connector[]
  objectMappings     ObjectMapping[]
  objectInstances    ObjectInstance[]
  syncJobs           SyncJob[]
  datasets           Dataset[]
  datasetRows        DatasetRow[]
  conversations      Conversation[]
  skillDefinitions   SkillDefinition[]
  auditLogs          AuditLog[]
  actionDefinitions  ActionDefinition[]
  actionPreviews     ActionPreview[]
  actionRuns         ActionRun[]
  ontologyDraft      OntologyDraft?
  evalQuestions      EvalQuestion[]
  researchDocuments  ResearchDocument[]
  documentChunks     DocumentChunk[]
  pipelines          Pipeline[]
  pipelineRuns       PipelineRun[]

  @@map("tenants")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  users  User[]

  @@unique([tenantId, name])
  @@map("roles")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String
  name         String
  passwordHash String   @map("password_hash")
  roleId       String   @map("role_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  role          Role           @relation(fields: [roleId], references: [id])
  conversations Conversation[]
  auditLogs     AuditLog[]
  actionPreviews ActionPreview[]
  actionRuns    ActionRun[]

  @@unique([tenantId, email])
  @@map("users")
}

model ObjectType {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  name              String
  label             String
  description       String?
  properties        Json     @default("[]")
  derivedProperties Json     @default("[]") @map("derived_properties")
  version           Int      @default(1)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  sourceRelations ObjectRelationship[] @relation("SourceType")
  targetRelations ObjectRelationship[] @relation("TargetType")
  mappings        ObjectMapping[]
  indexes         ObjectTypeIndex[]
  pipelines       Pipeline[]

  @@unique([tenantId, name])
  @@map("object_types")
}

model ObjectTypeIndex {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  objectTypeId String   @map("object_type_id") @db.Uuid
  field        String
  kind         String
  indexName    String   @unique @map("index_name")
  createdAt    DateTime @default(now()) @map("created_at")

  objectType ObjectType @relation(fields: [objectTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, objectTypeId, field, kind])
  @@index([tenantId, objectTypeId])
  @@map("object_type_indexes")
}

model ObjectRelationship {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  sourceTypeId String   @map("source_type_id") @db.Uuid
  targetTypeId String   @map("target_type_id") @db.Uuid
  name         String
  cardinality  String
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  sourceType ObjectType @relation("SourceType", fields: [sourceTypeId], references: [id])
  targetType ObjectType @relation("TargetType", fields: [targetTypeId], references: [id])

  @@unique([tenantId, sourceTypeId, name])
  @@map("object_relationships")
}

model Connector {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  type      String
  config    Json     @default("{}")
  status    String   @default("inactive")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  mappings ObjectMapping[]
  syncJobs SyncJob[]
  datasets Dataset[]
  pipelines Pipeline[]

  @@unique([tenantId, name])
  @@map("connectors")
}

model ObjectMapping {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  objectTypeId         String   @map("object_type_id") @db.Uuid
  connectorId          String?  @map("connector_id") @db.Uuid
  propertyMappings     Json     @default("{}") @map("property_mappings")
  relationshipMappings Json     @default("{}") @map("relationship_mappings")
  createdAt            DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  objectType ObjectType  @relation(fields: [objectTypeId], references: [id])
  connector  Connector?  @relation(fields: [connectorId], references: [id])
  syncJobs   SyncJob[]

  @@unique([tenantId, objectTypeId])
  @@map("object_mappings")
}

model ObjectInstance {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  objectType   String   @map("object_type")
  externalId   String   @map("external_id")
  label        String?
  properties   Json     @default("{}")
  relationships Json    @default("{}")
  sourceRef    Json?    @map("source_ref")
  searchText   String?  @map("search_text")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, objectType, externalId])
  @@index([tenantId, objectType])
  @@index([tenantId, objectType, deletedAt])
  @@map("object_instances")
}

/// Materialised, versioned snapshot of raw data from a Connector (ADR-0040 §2).
/// Dataset rows are the staging layer before SyncJobs write to object_instances.
model Dataset {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  connectorId String   @map("connector_id") @db.Uuid
  name        String
  kind        String   @default("clean")
  status      String   @default("draft")
  version     Int      @default(1)
  rowCount    Int      @default(0) @map("row_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  connector Connector       @relation(fields: [connectorId], references: [id])
  rows      DatasetRow[]
  syncJobs  SyncJob[]
  pipelineRunsAsInput  PipelineRun[] @relation("PipelineRunInput")
  pipelineRunsAsOutput PipelineRun[] @relation("PipelineRunOutput")

  @@unique([tenantId, name, version])
  @@map("datasets")
}

/// One row in a Dataset (ADR-0040 §2). JSONB columns mirror object_instances.properties shape.
model DatasetRow {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  datasetId String   @map("dataset_id") @db.Uuid
  rowIndex  Int      @map("row_index")
  columns   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([tenantId, datasetId])
  @@map("dataset_rows")
}

model SyncJob {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  connectorId      String?   @map("connector_id") @db.Uuid
  datasetId        String?   @map("dataset_id") @db.Uuid
  mappingId        String?   @map("mapping_id") @db.Uuid
  pgBossJobId      String?   @map("pg_boss_job_id")
  status           String    @default("pending")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  recordsProcessed Int       @default(0) @map("records_processed")
  recordsFailed    Int       @default(0) @map("records_failed")
  errorLog         Json?     @map("error_log")
  createdAt        DateTime  @default(now()) @map("created_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  connector Connector?     @relation(fields: [connectorId], references: [id])
  dataset   Dataset?       @relation(fields: [datasetId], references: [id])
  mapping   ObjectMapping? @relation(fields: [mappingId], references: [id])

  @@map("sync_jobs")
}

model Pipeline {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  name               String
  connectorId        String   @map("connector_id") @db.Uuid
  outputObjectTypeId String   @map("output_object_type_id") @db.Uuid
  status             String   @default("active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  connector        Connector      @relation(fields: [connectorId], references: [id])
  outputObjectType ObjectType     @relation(fields: [outputObjectTypeId], references: [id])
  steps            PipelineStep[]
  runs             PipelineRun[]

  @@unique([tenantId, connectorId, outputObjectTypeId])
  @@map("pipelines")
}

model PipelineStep {
  id         String   @id @default(uuid()) @db.Uuid
  pipelineId String   @map("pipeline_id") @db.Uuid
  order      Int
  type       String
  config     Json     @default("{}")
  name       String?
  createdAt  DateTime @default(now()) @map("created_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, order])
  @@map("pipeline_steps")
}

model PipelineRun {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  pipelineId       String    @map("pipeline_id") @db.Uuid
  inputDatasetId   String    @map("input_dataset_id") @db.Uuid
  outputDatasetId  String?   @map("output_dataset_id") @db.Uuid
  status           String    @default("pending")
  pgBossJobId      String?   @map("pg_boss_job_id")
  recordsProcessed Int?      @map("records_processed")
  error            Json?
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  pipeline     Pipeline @relation(fields: [pipelineId], references: [id])
  inputDataset Dataset  @relation("PipelineRunInput", fields: [inputDatasetId], references: [id])
  outputDataset Dataset? @relation("PipelineRunOutput", fields: [outputDatasetId], references: [id])

  @@map("pipeline_runs")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String?
  surface   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant             @relation(fields: [tenantId], references: [id])
  user   User               @relation(fields: [userId], references: [id])
  turns  ConversationTurn[]

  @@map("conversations")
}

model ConversationTurn {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String?
  toolCalls      Json?    @map("tool_calls")
  toolResults    Json?    @map("tool_results")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
  @@map("conversation_turns")
}

model SkillDefinition {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String?  @map("tenant_id") @db.Uuid
  name              String
  description       String?
  triggerConditions Json?    @map("trigger_conditions")
  content           String
  isAlwaysOn        Boolean  @default(false) @map("is_always_on")
  priority          Int      @default(0)
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@map("skill_definitions")
}

model AuditLog {
  id                       String   @id @default(uuid()) @db.Uuid
  tenantId                 String   @map("tenant_id") @db.Uuid
  actorId                  String   @map("actor_id") @db.Uuid
  actorType                String   @map("actor_type")
  operation                String
  objectType               String?  @map("object_type")
  queryPlan                Json?    @map("query_plan")
  resultCount              Int?     @map("result_count")
  source                   String?
  effectivePermissionFilter String? @map("effective_permission_filter")
  compiledSqlHash          String?  @map("compiled_sql_hash")
  createdAt                DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User   @relation(fields: [actorId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model ActionDefinition {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  name                 String
  label                String
  description          String   @default("")
  objectType           String   @map("object_type")
  parameters           Json     @default("[]")
  precondition         String?
  effects              Json     @default("[]")
  inputSchema          Json     @default("{}") @map("input_schema")
  preconditions        Json     @default("[]")
  permission           String   @default("object.write")
  requiresConfirmation Boolean  @default(true) @map("requires_confirmation")
  riskLevel            String   @default("low") @map("risk_level")
  createdAt            DateTime @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  previews ActionPreview[]

  @@unique([tenantId, name])
  @@map("action_definitions")
}

model ActionPreview {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  actionDefId   String    @map("action_def_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  targetIds     String[]  @map("target_ids") @db.Uuid
  inputParams   Json      @default("{}") @map("input_params")
  previewResult Json      @default("{}") @map("preview_result")
  status        String    @default("pending")
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  actionDef ActionDefinition @relation(fields: [actionDefId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  runs      ActionRun[]

  @@map("action_previews")
}

model ActionRun {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  previewId   String    @map("preview_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  status      String    @default("pending")
  result      Json?
  error       Json?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  preview ActionPreview @relation(fields: [previewId], references: [id])
  user    User          @relation(fields: [userId], references: [id])

  @@map("action_runs")
}

/// Lightweight ontology Draft state (ADR-0031): at most one row per tenant holding a
/// JSON snapshot of the entire ontology. The live `object_types`/`object_relationships`
/// tables remain the sole source for all runtime read paths; this table is design-time
/// only. Discarding the Draft = deleting the row.
model OntologyDraft {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @unique @map("tenant_id") @db.Uuid
  snapshot  Json     @default("{}")
  status    String   @default("editing")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("ontology_drafts")
}

/// Accuracy Evals question bank (ADR-0033): per-tenant design-time data, not test code.
/// Each row is one captured question + its expected query-plan baseline (the tool name
/// and args back-translated for display). `passHistory` accumulates per-run pass rates
/// for the N-repetition runner (#75). Lives per tenant; carried (de-identified) into
/// templates (#76).
model EvalQuestion {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  question      String
  baselineTool  String   @map("baseline_tool")
  baselineArgs  Json     @default("{}") @map("baseline_args")
  planSummary   String?  @map("plan_summary")
  passHistory   Json     @default("[]") @map("pass_history")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("eval_questions")
}

/// Per-OPC private ontology template (ADR-0034): a de-identified snapshot + Evals question
/// bank in tenant-INDEPENDENT storage (no FK to a tenant), so the OPC can reuse a tuned,
/// validated ontology across clients. Carries reusable business knowledge (structure,
/// annotations, allowedValues, externalId names, question bank); never client privacy
/// (instances, tenant_id, connector credentials). Not a community marketplace — private toolbox.
model OntologyTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  snapshot     Json     @default("{}")
  questionBank Json     @default("[]") @map("question_bank")
  /// Soft attribution of which tenant saved it; NOT a scoping constraint (templates are shared).
  ownerTenantId String? @map("owner_tenant_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ontology_templates")
}

/// A research document ingested into the market-intelligence archive (ADR-0042 §2). The
/// document is *provenance*, never a star Object Type: it carries the classification spine
/// (品类/机构/季度) and a reference to the original file in the BlobStore, so a narrative
/// answer can cite "据 <机构> <季度> 报告第 N 页" and the reader can open the source.
model ResearchDocument {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  /// Canonical 品类 (CategoryVocabulary) — the join key to AVC market metrics.
  category  String
  /// 机构: the research agency that produced the report (e.g. 艾瑞, 奥维云网).
  agency    String?
  /// 季度: the reporting period (e.g. 2025Q2), free-text as declared at ingest.
  quarter   String?
  title     String?
  /// BlobStore reference to the original file (so a citation is openable).
  mediaRef  String   @map("media_ref")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  chunks DocumentChunk[]

  @@index([tenantId, category])
  @@map("research_documents")
}

/// One embedded text chunk of a ResearchDocument (ADR-0042 §2). The enrichment layer hung
/// on the 品类 spine: semantic retrieval pre-filters by category/price-band, then ranks by
/// vector distance. The `embedding` column is a pgvector `vector(1024)` (doubao-embedding-
/// large-text truncated to 1024 dims); Prisma cannot type it, so it is declared Unsupported
/// and all reads/writes of the vector go through raw SQL.
model DocumentChunk {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  /// Canonical 品类 (denormalised from the document) — the semantic-search pre-filter key.
  category   String
  /// Optional canonical 价格段 label, when the chunk is about a specific band.
  priceBand  String?  @map("price_band")
  text       String
  /// 1-based page anchor in the source document, for provenance.
  page       Int
  embedding  Unsupported("vector(1024)")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  document ResearchDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId, category])
  @@map("document_chunks")
}
