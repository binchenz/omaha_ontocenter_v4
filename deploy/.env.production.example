# ── Database ──────────────────────────────────────────────────────────────────
# Password for the postgres user inside the docker-compose postgres container.
POSTGRES_PASSWORD=change-me-in-production

# ── Auth ──────────────────────────────────────────────────────────────────────
# Optional: leave unset and the Setup Wizard generates a random secret on first
# run. Set explicitly only if you run multiple API replicas behind a load balancer
# (all replicas must share the same secret): openssl rand -hex 32
# JWT_SECRET=
# Optional: token expiry (default: 7d)
# JWT_EXPIRES_IN=7d

# ── Connector encryption ──────────────────────────────────────────────────────
# Optional: leave unset and the Setup Wizard generates a random key on first run.
# Set explicitly only if you need a stable value across redeployments — changing
# this after connectors are created makes existing passwords undecryptable.
# CONNECTOR_ENCRYPTION_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=deepseek
# Optional: the Setup Wizard collects and stores this on first run. Set here only
# to override or for headless/automated setups.
# DEEPSEEK_API_KEY=

# ── Embeddings (ARK / doubao-embedding-large-text) ────────────────────────────
# Required for semantic retrieval. Leave empty to disable.
ARK_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of core-api as seen from the browser (use your public domain in production)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Server (optional) ────────────────────────────────────────────────────────
# LOG_LEVEL=info
