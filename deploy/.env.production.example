# ── Database ──────────────────────────────────────────────────────────────────
# Password for the postgres user inside the docker-compose postgres container.
POSTGRES_PASSWORD=change-me-in-production

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED: generate with `openssl rand -hex 32`
JWT_SECRET=change-me-in-production
# Optional: token expiry (default: 7d)
# JWT_EXPIRES_IN=7d

# ── Connector encryption ──────────────────────────────────────────────────────
# REQUIRED: must be exactly 32 characters; generate with `openssl rand -hex 16`
CONNECTOR_ENCRYPTION_KEY=change-me-32-chars-in-production

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key

# ── Embeddings (ARK / doubao-embedding-large-text) ────────────────────────────
# Required for semantic retrieval. Leave empty to disable.
ARK_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of core-api as seen from the browser (use your public domain in production)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Server (optional) ────────────────────────────────────────────────────────
# LOG_LEVEL=info
