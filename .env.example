# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://omaha:omaha@localhost:5434/ontocenter?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────────
# Optional: leave unset and the Setup Wizard generates a random secret into the
# database on first run. Set explicitly only to pin a secret across deployments
# (e.g. multiple API replicas behind a load balancer): openssl rand -hex 32
# JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Connector encryption ──────────────────────────────────────────────────────
# Optional: leave unset and the Setup Wizard generates a random key into the
# database on first run. Set explicitly only to pin it across deployments; must
# be a stable value or existing connector passwords become undecryptable.
# CONNECTOR_ENCRYPTION_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=deepseek
# Optional: the Setup Wizard collects and stores this on first run. Set here only
# to override or for headless setups.
# DEEPSEEK_API_KEY=
# Optional: LLM call timeout in ms (default: 30000)
# LLM_TIMEOUT_MS=30000

# ── Embeddings (火山引擎 ARK, doubao-embedding-large-text) ─────────────────────
# Required for research-document semantic retrieval (ADR-0042). Unit tests use a
# fake; only real ingestion/retrieval needs this.
ARK_API_KEY=your-ark-key-here

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of core-api as seen from the browser
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Server ────────────────────────────────────────────────────────────────────
# Optional: core-api listen port (default: 3001)
# PORT=3001
# Optional: log level — trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info
# Optional: query timeout in ms (default: 5000)
# QUERY_TIMEOUT_MS=5000
# Optional: dump every LLM call (assembled prompt + tools + raw response) to
# .llm-debug/*.json for prompt debugging. Off by default — set to 1 to enable.
# LLM_DEBUG=1
# Optional: directory for LLM debug dumps (default: .llm-debug)
# LLM_DEBUG_DIR=.llm-debug
