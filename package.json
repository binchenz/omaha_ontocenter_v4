{
  "name": "omaha-ontocenter",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @omaha/db run generate",
    "db:migrate": "pnpm --filter @omaha/db run migrate",
    "db:migrate:deploy": "pnpm --filter @omaha/db run migrate:deploy",
    "db:push": "pnpm --filter @omaha/db run push",
    "db:seed": "pnpm --filter @omaha/db run seed",
    "seed:demo": "pnpm --filter @omaha/scripts exec tsx seed-demo.ts",
    "setup": "pnpm install && pnpm db:generate && pnpm db:migrate",
    "setup:demo": "pnpm setup && pnpm db:seed"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@9.15.0"
}
